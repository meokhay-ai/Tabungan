# ---- Tabungan environment ----
NODE_ENV=development

# Public (exposed to the browser)
NEXT_PUBLIC_APP_NAME=Tabungan
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Database (Postgres) — Drizzle reads this var name
DRIZZLE_DATABASE_URL=postgresql://user:pass@host:5432/db_tabungan

# Stellar (testnet)
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Soroban — FamilyVault contract (deposits, allowances, claims) + native XLM SAC
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_CONTRACT_ID=CBCA73FAZFZUR5NFXOSC45WRHBUY7WKQBII7PVFTJLRY3IHREVQPD7RB
NEXT_PUBLIC_SOROBAN_CONTRACT_ID=CBCA73FAZFZUR5NFXOSC45WRHBUY7WKQBII7PVFTJLRY3IHREVQPD7RB
VAULT_TOKEN_SAC=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Sessions
SESSION_SECRET=replace-with-a-string-at-least-32-chars-long
SESSION_COOKIE_NAME=tabungan_session
SESSION_TTL_SECONDS=604800
NONCE_TTL_SECONDS=300

# USDC asset (testnet issuer)
USDC_ASSET_CODE=USDC
USDC_ASSET_ISSUER_TESTNET=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# Public keys excluded from /api/stats (comma-separated). Empty by default —
# there is no seeded data, so every metric is real.
DEMO_EXCLUDE_KEYS=
